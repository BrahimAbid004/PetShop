<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0"
         metadata-complete="false">
    <servlet>
        <servlet-name>MaServletCatalogue</servlet-name>
        <servlet-class>com.petshop.controller.CatalogueServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>MaServletCatalogue</servlet-name>
        <url-pattern>/catalogue</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MaServletPanier</servlet-name>
        <servlet-class>com.petshop.controller.PanierServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MaServletPanier</servlet-name>
        <url-pattern>/panier</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>MaServletLogin</servlet-name>
        <servlet-class>com.petshop.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MaServletLogin</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
</web-app>